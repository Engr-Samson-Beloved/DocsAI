# Google Gemini API Key for DocuAI
# Copy this file to .env.local and insert your actual API key.
# Get your free API key at: https://aistudio.google.com/
GEMINI_API_KEY=

# xAI Grok API Key (Optional failover/search provider)
GROK_API_KEY=

# Groq API Key (Optional Llama 3 generation provider)
GROQ_API_KEY=
